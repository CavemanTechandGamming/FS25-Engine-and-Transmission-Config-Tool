# =============================================================================
# Paths listed below stay on your machine (or CI artifacts). They are NOT
# uploaded to GitHub when you push.
#
# This .gitignore file itself SHOULD be committed — that is normal and expected.
# =============================================================================

# Byte-compiled / cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/

# Virtual environments (local only — never commit)
.venv/
venv/
env/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# PyInstaller (local only — publish via Actions artifacts if needed)
build/
dist/
*.spec

# Local packaged binaries
*.exe
*.msi
*.dmg

# Local draft for pasting into the GitHub Release description (Markdown).
RELEASE_BODY.md

# Local-only notes (never commit — personal / future work reminders)
LOCAL_NOTES.md

# Runtime data next to the app / project root (portable presets, settings, logs)
/Custom Presets/
/settings.json
/fs25_config_tool.log
/fs25_config_tool.log.*
